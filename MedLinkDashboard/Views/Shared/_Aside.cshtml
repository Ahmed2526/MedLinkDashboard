@if (User.Identity.IsAuthenticated)
{
    <!-- ========== App Menu ========== -->
    <div class="app-menu navbar-menu">
        <!-- LOGO -->
        <div class="navbar-brand-box">
            <!-- Dark Logo-->
            <a asp-controller="Home" asp-action="Index" class="logo logo-dark">
                <span class="logo-sm">
                    <img src="~/assets/images/logo-sm.png" alt="" height="22">
                </span>
                <span class="logo-lg">
                    <img src="~/assets/images/logo-dark.png" alt="" height="17">
                </span>
            </a>
            <!-- Light Logo-->
            <a asp-controller="Home" asp-action="Index" class="logo logo-light">
                <span class="logo-sm">
                    <img src="~/assets/images/logo-sm.png" alt="" height="22">

                </span>
                <span class="logo-lg">
                    <img src="~/assets/images/logo-light.png" alt="" height="17">

                </span>
            </a>
            <button type="button" class="btn btn-sm p-0 fs-20 header-item float-end btn-vertical-sm-hover" id="vertical-hover">
                <i class="ri-record-circle-line"></i>
            </button>
        </div>

        <div id="scrollbar">
            <div class="container-fluid">

                <div id="two-column-menu">
                </div>
                <ul class="navbar-nav" id="navbar-nav">
                    <li class="menu-title"><span data-key="t-menu">Menu</span></li>
                    <li class="nav-item">
                        <a class="nav-link menu-link" href="#sidebarDashboards" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarDashboards">
                            <i data-feather="home" class="icon-dual"></i> <span data-key="t-Home">Home</span>
                        </a>
                        <div class="collapse menu-dropdown" id="sidebarDashboards">
                            <ul class="nav nav-sm flex-column">
                                <li class="nav-item">
                                    <a asp-controller="Specialities" asp-action="Index" class="nav-link" data-key="t-Specialities"> Specialities </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="Doctors" asp-action="Index" class="nav-link" data-key="t-Doctors"> Doctors </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="Patients" asp-action="Index" class="nav-link" data-key="t-Patients"> Patients </a>
                                </li>
                            </ul>
                        </div>
                    </li>


                    <li class="menu-title"><i class="ri-more-fill"></i> <span data-key="t-pages">Pages</span></li>

                    <li class="nav-item">
                        <a class="nav-link menu-link" href="#sidebarAuth" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="sidebarAuth">
                            <i data-feather="users" class="icon-dual"></i> <span data-key="t-Roles&Permissions">Roles&Permissions</span>
                        </a>
                        <div class="collapse menu-dropdown" id="sidebarAuth">
                            <ul class="nav nav-sm flex-column">
                                <li class="nav-item">
                                    <a asp-controller="Roles" asp-action="Index" class="nav-link" data-key="t-Roles"> Roles </a>
                                </li>
                            </ul>
                        </div>
                    </li>


                </ul>
            </div>
        </div>
        <!-- Sidebar -->
        <div class="sidebar-background"></div>
    </div>
    <!-- Left Sidebar End -->
    <!-- Vertical Overlay-->
    <div class="vertical-overlay"></div>
}