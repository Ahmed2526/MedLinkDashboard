@model ProfileVM

@{
    ViewData["Title"] = "Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <img src="~/assets/images/users/avatar-8.jpg"
                             class="rounded-circle mb-3" alt="Profile Picture" width="120" height="120">
                        <h4 class="card-title mb-0">@Model.UserName</h4>
                        <p class="text-muted">@string.Join(", ", Model.Role)</p>
                    </div>

                    <hr />

                    <div class="mb-3 d-flex justify-content-between">
                        <h6 class="mb-0">Email:</h6>
                        <p class="text-muted mb-0">@Model.Email</p>
                    </div>

                    <div class="mb-3 d-flex justify-content-between">
                        <h6 class="mb-0">Phone Number:</h6>
                        <p class="text-muted mb-0">@Model.PhoneNumber</p>
                    </div>

                    <div class="text-center mt-4">
                        <a href="/ComingSoon" class="btn btn-primary px-4">
                            <i class="bi bi-pencil-square"></i> Edit Profile
                        </a>
                        <a asp-action="Signout" class="btn btn-outline-danger px-4 ms-2">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
