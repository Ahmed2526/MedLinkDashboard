@{
    ViewData["Title"] = "Access Denied";
    ViewData["PageContentClass"] = "";
    ViewData["mainContentClass"] = ""; // removes class
    ViewData["containerfluidClass"] = "";
}

<div class="d-flex align-items-center justify-content-center vh-100">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-shield-lock-fill text-danger display-1"></i>
        </div>
        <h1 class="display-4 fw-bold text-danger">Access Denied</h1>
        <p class="text-muted fs-5 mt-3">
            Sorry, you don’t have permission to view this page.
        </p>
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                <i class="bi bi-house-door"></i> Back to Home
            </a>
            <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-secondary px-4 ms-2">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
        </div>
    </div>
</div>
